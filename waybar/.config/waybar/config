{
	"height": 32,
	"spacing": 0,
	"modules-left": ["sway/workspaces", "sway/window", "custom/media"],
	"modules-center": ["custom/weather"],
	"modules-right": [
		"network",
		"pulseaudio",
		"clock",
		"clock#date",
		"battery",
		"custom/quicksettings",
		"tray"
	],
	"sway/mode": {
		"format": "<span style=\"italic\">{}</span>"
	},
	"sway/scratchpad": {
		"format": "{icon} {count}",
		"show-empty": false,
		"format-icons": ["", "пЛТ"],
		"tooltip": true,
		"tooltip-format": "{app}: {title}"
	},
	"sway/window": {
		"format": "{title}",
		"empty-format": "No active window",
		"on-click": "ags -t datemenu",
		"tooltip": false
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "пБЃ",
			"deactivated": "пБ∞"
		}
	},
	"tray": {
		"spacing": 10
	},
	"clock": {
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "{:%Y-%m-%d}"
	},
	"clock#date": {
		"format": "{:%d.%m.%Y}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "рЯФЛ {capacity}%",
		"format-plugged": "пЗ¶ {capacity}%",
		"format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"],
		"on-click": "gnome-control-center power"
	},
	"pulseaudio": {
		"format": "{icon} {volume}% {format_source}",
		"format-bluetooth": "пКФ {icon} {volume}% {format_source}",
		"format-bluetooth-muted": "пЪ© пКФ {icon} {format_source}",
		"format-muted": "пЪ©  {format_source}",
		"format-source": "пД∞ {volume}%",
		"format-source-muted": "пД±",
		"format-icons": {
			"default": ["пА¶", "пАІ", "пА®"]
		},
		"on-click": "pavucontrol"
	},
	"custom/weather": {
		"format": "{}",
		"interval": 3600,
		"exec": "bash /home/jose/.config/waybar/scripts/get-current-weather.sh",
		"exec-if": "ping -c1 wttr.in >/dev/null 2>&1"
	},
	"custom/vpn": {
		"tooltip": false,
		"format": "VPN {}",
		"exec": "mullvad status | grep -q 'Connected' && echo 'пА£' || echo 'пВЬ'",
		"interval": 5,
		"on-click": "mullvad connect",
		"on-click-right": "mullvad disconnect"
	},
	"network": {
		"format-wifi": "пЗЂ {essid} ({signalStrength}%)",
		"format-ethernet": "вђЗ{bandwidthDownBytes} вђЖ{bandwidthUpBytes}",
		"interval": 3,
		"format-linked": "{ifname} (No IP) пЮЦ",
		"format": "пАТ",
		"format-disconnected": "пЪФ",
		"format-alt": "{ifname}: {ipaddr}/{cidr}",
		"on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
		"tooltip-format": "пВУ {bandwidthUpBits} пАЩ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
		"tooltip-format-wifi": "пЗЂ {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nпВУ {bandwidthUpBits} пАЩ {bandwidthDownBits}",
		"min-length": 17,
		"max-length": 17
	},

	"custom/quicksettings": {
		"format": "пМГ",
		"on-click": "bash /home/jose/.config/waybar/scripts/quicksettings.sh"
	}
}
